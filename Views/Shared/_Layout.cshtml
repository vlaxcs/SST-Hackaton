<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Yestes</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SST_Hackaton.styles.css" asp-append-version="true" />
</head>
<body class="mystic-body">
    <div class="mystic-backdrop"></div>
    <div class="mystic-orb mystic-orb-left"></div>
    <div class="mystic-orb mystic-orb-right"></div>
    <header class="mystic-header">
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark mystic-nav mb-4">
            <div class="container-fluid px-4">
                <a class="navbar-brand brand-mystic" asp-area="" asp-controller="Notes" asp-action="Index">Yestes</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 gap-sm-2">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Notes" asp-action="Index">Notițe</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Notes" asp-action="Index" asp-route-openNewNoteModal="1">Notiță nouă</a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container pb-5">
        <main role="main" class="pb-3 mystic-main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted mystic-footer">
        <div class="container">
            &copy; 2026 - Yestes
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
