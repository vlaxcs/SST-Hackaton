@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav align-items-sm-center gap-sm-1">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        Salut, @User.Identity?.Name!
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Notes", new { area = "" })">
            <button type="submit" class="nav-link btn btn-link">Deconectare</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link" asp-area="Identity" asp-page="/Account/Register">Înregistrare</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">Autentificare</a>
    </li>
}
</ul>
