@model Note
@{
    ViewData["Title"] = "Vizualizare si editare";
}

<h1>Vizualizare si editare</h1>
<hr />
<div class="row">
    <div class="col-md-9 col-lg-8">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Content" class="form-label"></label>
                <textarea asp-for="Content" class="form-control" rows="8"></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <h5 class="mb-2">Atasamente existente</h5>
                @if (Model.Attachments.Any())
                {
                    <div class="row g-3 mb-3">
                        @foreach (var attachment in Model.Attachments.OrderByDescending(a => a.UploadedAtUtc))
                        {
                            <div class="col-md-6 col-lg-4">
                                <div class="card p-2 h-100">
                                    @if ((attachment.ContentType ?? string.Empty).StartsWith("audio/"))
                                    {
                                        <audio class="w-100 mb-2" controls preload="metadata">
                                            <source src="@Url.Action("PreviewAttachment", "Notes", new { id = attachment.Id })" type="@attachment.ContentType" />
                                        </audio>
                                    }
                                    else if ((attachment.ContentType ?? string.Empty).StartsWith("video/"))
                                    {
                                        <video class="w-100 rounded border mb-2" controls preload="metadata" playsinline>
                                            <source src="@Url.Action("PreviewAttachment", "Notes", new { id = attachment.Id })" type="@attachment.ContentType" />
                                        </video>
                                    }
                                    else if ((attachment.ContentType ?? string.Empty).StartsWith("image/"))
                                    {
                                        <a href="@Url.Action("PreviewAttachment", "Notes", new { id = attachment.Id })" target="_blank" rel="noopener">
                                            <img src="@Url.Action("PreviewAttachment", "Notes", new { id = attachment.Id })" alt="Preview atasament" class="img-fluid rounded border mb-2" style="max-height: 220px;" />
                                        </a>
                                    }
                                    else
                                    {
                                        <a href="@Url.Action("PreviewAttachment", "Notes", new { id = attachment.Id })" target="_blank" rel="noopener" class="btn btn-sm btn-outline-secondary mb-2">Deschide in aplicatie</a>
                                    }

                                    <div class="small text-muted mb-2">@attachment.OriginalFileName</div>
                                    <div class="small text-muted mb-2">@(Math.Round(attachment.SizeBytes / 1024.0)) KB</div>
                                    <div class="d-flex gap-2 mt-auto">
                                        <a asp-action="DownloadAttachment" asp-route-id="@attachment.Id" class="btn btn-sm btn-outline-primary flex-fill">Descarca</a>
                                        <a class="btn btn-sm btn-outline-danger flex-fill" href="@Url.Action("DeleteAttachment", "Notes", new { id = attachment.Id })" onclick="return confirm('Esti sigur ca vrei sa stergi acest atasament?');">Sterge</a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="small text-muted mb-3">Nu exista atasamente inca.</div>
                }
            </div>

            <div class="mb-3">
                <label for="uploadedFiles" class="form-label">Adauga atasamente noi</label>
                <input id="uploadedFiles" name="uploadedFiles" type="file" class="form-control" multiple />
                <span class="text-danger" data-valmsg-for="uploadedFiles"></span>
            </div>

            <div class="small text-muted mb-3">
                <div>Creat: @Model.CreatedAtUtc.ToLocalTime().ToString("f")</div>
                <div>Modificat: @Model.ModifiedAtUtc.ToLocalTime().ToString("f")</div>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <input type="submit" value="Salveaza modificarile" class="btn btn-primary" />
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Sterge notita</a>
                <a asp-action="Index" class="btn btn-outline-secondary">Inapoi la lista</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
