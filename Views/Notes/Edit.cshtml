@model Note
@{
    ViewData["Title"] = "Editează notița";
}

<h1>Editează notița</h1>
<hr />
<div class="row">
    <div class="col-md-8 col-lg-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NoteTypeId" class="form-label"></label>
                <input type="hidden" asp-for="NoteTypeId" />
                <input type="text" class="form-control" value="@(Model.NoteTypeId == 2 ? "Listă de bifat" : "Text")" readonly />
                <span asp-validation-for="NoteTypeId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Content" class="form-label"></label>
                <textarea asp-for="Content" class="form-control d-none" rows="8"></textarea>
                <textarea id="textContentEditor" class="form-control" rows="8" placeholder="Scrie conținutul notiței aici..."></textarea>
                <div id="checklistEditor" class="d-none">
                    <div class="input-group mb-2">
                        <input id="newChecklistItem" type="text" class="form-control" placeholder="Adaugă un element în listă" />
                        <button id="addChecklistItemBtn" class="btn btn-outline-primary" type="button">Adaugă</button>
                    </div>
                    <ul id="checklistItems" class="list-group"></ul>
                </div>
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <input type="submit" value="Salvează" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-outline-secondary">Înapoi la listă</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (() => {
            const TYPE_TEXT = "1";
            const TYPE_CHECKBOX = "2";

            const noteType = document.getElementById("NoteTypeId");
            const hiddenContent = document.getElementById("Content");
            const textEditor = document.getElementById("textContentEditor");
            const checklistEditor = document.getElementById("checklistEditor");
            const checklistItems = document.getElementById("checklistItems");
            const newChecklistItem = document.getElementById("newChecklistItem");
            const addChecklistItemBtn = document.getElementById("addChecklistItemBtn");
            const isChecklistType = noteType.value === TYPE_CHECKBOX;

            let items = parseChecklist(hiddenContent.value);

            function parseChecklist(raw) {
                if (!raw || !raw.trim()) {
                    return [];
                }

                try {
                    const parsed = JSON.parse(raw);
                    if (Array.isArray(parsed)) {
                        return parsed
                            .map(i => ({
                                text: typeof i?.text === "string" ? i.text : (typeof i?.Text === "string" ? i.Text : ""),
                                isChecked: i?.isChecked ?? i?.IsChecked ?? false
                            }))
                            .filter(i => i.text.trim().length > 0)
                            .map(i => ({ text: i.text.trim(), isChecked: !!i.isChecked }));
                    }
                } catch (error) {
                }

                return raw
                    .split("\n")
                    .map(line => line.trim())
                    .filter(line => line.length > 0)
                    .map(line => ({ text: line, isChecked: false }));
            }

            function syncContent() {
                if (isChecklistType) {
                    hiddenContent.value = JSON.stringify(items);
                } else {
                    hiddenContent.value = textEditor.value;
                }
            }

            function renderChecklist() {
                checklistItems.innerHTML = "";
                items.forEach((item, index) => {
                    const li = document.createElement("li");
                    li.className = "list-group-item d-flex justify-content-between align-items-center gap-2";

                    const wrapper = document.createElement("label");
                    wrapper.className = "d-flex align-items-center gap-2 mb-0 flex-grow-1";

                    const checkbox = document.createElement("input");
                    checkbox.type = "checkbox";
                    checkbox.checked = item.isChecked;
                    checkbox.addEventListener("change", () => {
                        items[index].isChecked = checkbox.checked;
                        syncContent();
                    });

                    const text = document.createElement("span");
                    text.textContent = item.text;

                    wrapper.appendChild(checkbox);
                    wrapper.appendChild(text);

                    const removeBtn = document.createElement("button");
                    removeBtn.type = "button";
                    removeBtn.className = "btn btn-sm btn-outline-danger";
                    removeBtn.textContent = "Șterge";
                    removeBtn.addEventListener("click", () => {
                        items.splice(index, 1);
                        renderChecklist();
                    });

                    li.appendChild(wrapper);
                    li.appendChild(removeBtn);
                    checklistItems.appendChild(li);
                });

                syncContent();
            }

            function addItem() {
                const text = newChecklistItem.value.trim();
                if (!text) {
                    return;
                }

                items.push({ text, isChecked: false });
                newChecklistItem.value = "";
                renderChecklist();
                newChecklistItem.focus();
            }

            function toggleMode() {
                const isChecklist = isChecklistType;

                textEditor.classList.toggle("d-none", isChecklist);
                checklistEditor.classList.toggle("d-none", !isChecklist);

                if (!isChecklist) {
                    textEditor.value = hiddenContent.value;
                }

                if (isChecklist) {
                    items = parseChecklist(hiddenContent.value);
                    renderChecklist();
                }

                syncContent();
            }

            addChecklistItemBtn.addEventListener("click", addItem);
            newChecklistItem.addEventListener("keydown", event => {
                if (event.key === "Enter") {
                    event.preventDefault();
                    addItem();
                }
            });

            textEditor.addEventListener("input", syncContent);

            textEditor.value = hiddenContent.value;
            toggleMode();
        })();
    </script>
}
