@model Note
@{
    ViewData["Title"] = "Șterge notița";
}

<h1>Șterge notița</h1>
<div class="alert alert-warning">Sigur vrei să ștergi această notiță?</div>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <h4>@Model.Title</h4>
        <div class="text-muted mb-3">Notiță mixtă</div>
        <p style="white-space: pre-wrap;">@(string.IsNullOrWhiteSpace(Model.Content) ? "Fără descriere" : Model.Content)</p>

        @if (Model.Attachments.Any())
        {
            <h6 class="mt-3">Atașamente</h6>
            <ul class="list-group list-group-flush mb-3">
                @foreach (var attachment in Model.Attachments)
                {
                    <li class="list-group-item">@attachment.OriginalFileName</li>
                }
            </ul>
        }
    </div>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Șterge" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-outline-secondary">Renunță</a>
</form>
