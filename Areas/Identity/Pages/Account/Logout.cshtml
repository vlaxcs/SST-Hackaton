@page
@model LogoutModel
@{
    ViewData["Title"] = "Deconectare";
}

<header class="identity-shell mystic-panel p-4 p-md-5">
    <h1>@ViewData["Title"]</h1>
    @{
        if (User.Identity?.IsAuthenticated ?? false)
        {
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                <button type="submit" class="btn btn-primary">Confirmă deconectarea</button>
            </form>
        }
        else
        {
            <p>Te-ai deconectat cu succes din aplicație.</p>
        }
    }
</header>
